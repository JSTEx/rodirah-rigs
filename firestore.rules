rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // COLECCIÓN: solicitudes (Pública - Formulario)
    // ============================================
    match /solicitudes/{solicitud} {
      // Permitir lectura pública (para que el admin pueda verlas)
      allow read: if true;
      
      // Permitir creación pública (formulario de contacto)
      allow create: if true;
      
      // Solo usuarios autenticados pueden modificar/eliminar
      allow update, delete: if request.auth != null;
    }
    
    // ============================================
    // COLECCIÓN: cotizaciones (Pública - Solo escritura)
    // ============================================
    match /cotizaciones/{cotizacion} {
      // Lectura pública permitida
      allow read: if true;
      
      // Solo creación pública (desde el cotizador)
      allow create: if true;
      
      // Solo admin puede modificar/eliminar
      allow update, delete: if request.auth != null;
    }
    
    // ============================================
    // COLECCIÓN: servicios (Pública - Lectura)
    // ============================================
    match /servicios/{servicio} {
      // Lectura pública de servicios
      allow read: if true;
      
      // Solo admin puede escribir
      allow write: if request.auth != null;
    }
    
    // ============================================
    // COLECCIÓN: configuraciones (Pública - Lectura)
    // ============================================
    match /configuraciones/{config} {
      // Lectura pública de configuraciones
      allow read: if true;
      
      // Solo admin puede modificar
      allow write: if request.auth != null;
    }
    
    // ============================================
    // COLECCIONES PRIVADAS (Solo Admin)
    // ============================================
    match /{document=**} {
      // Todas las demás colecciones requieren autenticación
      allow read, write: if request.auth != null;
    }
  }
}